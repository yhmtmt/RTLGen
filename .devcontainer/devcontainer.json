{
  "name": "Ubuntu22-orfs",
  "build": {
    "dockerfile": "Dockerfile",
    "context": ".."
  },
  "mounts": [
    "source=${localEnv:HOME}/.codex,target=/root/.codex,type=bind"
  ],
  "runArgs": [
    "--platform=linux/amd64",
    "-p", "5432:5432",
    "-e", "DISPLAY=${env:DISPLAY}",
    "-v", "/tmp/.X11-unix:/tmp/.X11-unix"
  ],
  "containerEnv": {
    "RTLCP_DATABASE_URL": "postgresql+psycopg://rtlgen:rtlgen@localhost:5432/rtlgen_control_plane",
    "RTLCP_ROLE": "${localEnv:RTLCP_ROLE}"
  },
  "postStartCommand": "/workspaces/RTLGen/.devcontainer/start_control_plane_services.sh",
  "settings": {
    "terminal.integrated.defaultProfile.linux": "bash"
  },
  "extensions": [
    "ms-vscode.cpptools",
    "ms-vscode.cmake-tools"
  ],
  "remoteUser": "root"
}
