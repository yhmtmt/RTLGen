REPO_ROOT=/workspaces/RTLGen
VENV_PATH=/workspaces/RTLGen/control_plane/.venv

RTLCP_DATABASE_URL=postgresql+psycopg://rtlgen:rtlgen@localhost:5432/rtlgen_control_plane

RTLCP_REPO_SLUG=yhmtmt/RTLGen
RTLCP_EVALUATOR_ID=control_plane
RTLCP_EXECUTOR=@control_plane
RTLCP_PR_BASE=master

RTLCP_SUBMIT=1
RTLCP_FORCE=0

# Optional scoping:
# RTLCP_ITEM_ID=
# RTLCP_SESSION_ID=
# RTLCP_BRANCH_NAME=
# RTLCP_SNAPSHOT_TARGET_PATH=
# RTLCP_PACKAGE_TARGET_PATH=
# RTLCP_WORKTREE_ROOT=/tmp/rtlcp-submit
# RTLCP_COMMIT_MESSAGE=
