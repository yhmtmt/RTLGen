REPO_ROOT=/workspaces/RTLGen
VENV_PATH=/workspaces/RTLGen/control_plane/.venv

RTLCP_DATABASE_URL=postgresql+psycopg://rtlgen:rtlgen@<notebook-host-ip>:5432/rtlgen_control_plane

RTLCP_MACHINE_KEY=eval-daemon-<hostname>
RTLCP_HOSTNAME=<hostname>
RTLCP_EXECUTOR_KIND=local_process

RTLCP_CAPABILITY_FILTER_JSON={"platform":"nangate45","flow":"openroad"}
RTLCP_CAPABILITIES_JSON={"platform":"nangate45","flow":"openroad"}

RTLCP_POLL_SECONDS=15
RTLCP_MAX_ITEMS_PER_POLL=1
RTLCP_LEASE_SECONDS=1800
RTLCP_HEARTBEAT_SECONDS=30
RTLCP_MAX_RETRY_ATTEMPTS=2

RTLCP_STOP_ON_NO_WORK=0
RTLCP_ALLOW_STALE_CHECKOUT=0
RTLCP_DISABLE_SCHEDULER_MAINTENANCE=0

RTLCP_LOG_ROOT=/workspaces/RTLGen/control_plane/logs
