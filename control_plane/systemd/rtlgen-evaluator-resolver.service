[Unit]
Description=RTLGen control-plane evaluator resolver daemon
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=/workspaces/RTLGen
EnvironmentFile=/etc/rtlgen/evaluator-worker.env
ExecStart=/workspaces/RTLGen/control_plane/scripts/run_eval_resolver_service.sh
Restart=always
RestartSec=10
KillMode=process
TimeoutStopSec=30
NoNewPrivileges=true

[Install]
WantedBy=multi-user.target
