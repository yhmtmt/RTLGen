{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "RTLGen OpenROAD Evaluation Queue Item",
  "type": "object",
  "required": [
    "version",
    "item_id",
    "title",
    "layer",
    "flow",
    "state",
    "priority",
    "created_utc",
    "requested_by",
    "platform",
    "task",
    "handoff"
  ],
  "properties": {
    "version": { "const": 0.1 },
    "item_id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$",
      "minLength": 1
    },
    "title": { "type": "string", "minLength": 1 },
    "layer": { "type": "string", "enum": ["layer1", "layer2"] },
    "flow": { "type": "string", "const": "openroad" },
    "state": { "type": "string", "enum": ["queued", "evaluated"] },
    "priority": { "type": "integer", "minimum": 0, "maximum": 5 },
    "created_utc": { "type": "string", "minLength": 1 },
    "requested_by": { "type": "string", "minLength": 1 },
    "platform": { "type": "string", "minLength": 1 },
    "task": {
      "type": "object",
      "required": ["objective", "source_mode", "commands", "expected_outputs"],
      "properties": {
        "objective": { "type": "string", "minLength": 1 },
        "source_mode": { "type": "string", "enum": ["config", "src_verilog"] },
        "inputs": {
          "type": "object",
          "properties": {
            "configs": { "type": "array", "items": { "type": "string", "minLength": 1 } },
            "design_dirs": { "type": "array", "items": { "type": "string", "minLength": 1 } },
            "sweeps": { "type": "array", "items": { "type": "string", "minLength": 1 } },
            "macro_manifests": { "type": "array", "items": { "type": "string", "minLength": 1 } },
            "candidate_manifests": { "type": "array", "items": { "type": "string", "minLength": 1 } }
          },
          "additionalProperties": false
        },
        "commands": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["name", "run"],
            "properties": {
              "name": { "type": "string", "minLength": 1 },
              "run": { "type": "string", "minLength": 1 }
            },
            "additionalProperties": false
          }
        },
        "expected_outputs": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "acceptance": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      },
      "additionalProperties": false
    },
    "handoff": {
      "type": "object",
      "required": [
        "branch",
        "pr_title",
        "checklist",
        "identity_block_format",
        "pr_body_fields"
      ],
      "properties": {
        "branch": { "type": "string", "minLength": 1 },
        "pr_title": { "type": "string", "minLength": 1 },
        "identity_block_format": { "type": "string", "minLength": 1 },
        "pr_body_fields": {
          "type": "object",
          "required": ["evaluator_id", "session_id", "host", "queue_item_id"],
          "properties": {
            "evaluator_id": { "type": "string", "minLength": 1 },
            "session_id": { "type": "string", "minLength": 1 },
            "host": { "type": "string", "minLength": 1 },
            "queue_item_id": { "type": "string", "minLength": 1 }
          },
          "additionalProperties": false
        },
        "checklist": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        }
      },
      "additionalProperties": false
    },
    "result": {
      "type": ["object", "null"],
      "properties": {
        "completed_utc": { "type": "string", "minLength": 1 },
        "executor": { "type": "string", "minLength": 1 },
        "branch": { "type": "string", "minLength": 1 },
        "evaluator_id": { "type": "string", "minLength": 1 },
        "session_id": {
          "type": "string",
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$",
          "minLength": 1
        },
        "host": { "type": "string", "minLength": 1 },
        "queue_item_id": {
          "type": "string",
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$",
          "minLength": 1
        },
        "identity_block": { "type": "string", "minLength": 1 },
        "pr_number": { "type": "integer", "minimum": 1 },
        "status": { "type": "string", "enum": ["ok", "fail", "partial"] },
        "summary": { "type": "string", "minLength": 1 },
        "metrics_rows": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["metrics_csv", "platform", "status"],
            "properties": {
              "metrics_csv": { "type": "string", "minLength": 1 },
              "platform": { "type": "string", "minLength": 1 },
              "param_hash": { "type": "string", "minLength": 1 },
              "tag": { "type": "string", "minLength": 1 },
              "status": { "type": "string", "minLength": 1 },
              "result_path": { "type": "string", "minLength": 1 }
            },
            "anyOf": [
              { "required": ["param_hash"] },
              { "required": ["tag"] }
            ],
            "additionalProperties": false
          }
        },
        "notes": { "type": "string" }
      },
      "additionalProperties": false
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "state": { "const": "queued" }
        },
        "required": ["state"]
      },
      "then": {
        "properties": {
          "result": { "type": ["null", "object"] }
        }
      }
    },
    {
      "if": {
        "properties": {
          "state": { "const": "evaluated" }
        },
        "required": ["state"]
      },
      "then": {
        "required": ["result"],
        "properties": {
          "result": {
            "type": "object",
            "required": [
              "completed_utc",
              "executor",
              "branch",
              "evaluator_id",
              "session_id",
              "host",
              "queue_item_id",
              "identity_block",
              "status",
              "summary",
              "metrics_rows"
            ]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "task": {
            "properties": {
              "source_mode": { "const": "config" }
            },
            "required": ["source_mode"]
          }
        }
      },
      "then": {
        "properties": {
          "task": {
            "properties": {
              "inputs": {
                "required": ["configs"],
                "properties": {
                  "configs": {
                    "type": "array",
                    "minItems": 1
                  }
                }
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "task": {
            "properties": {
              "source_mode": { "const": "src_verilog" }
            },
            "required": ["source_mode"]
          }
        }
      },
      "then": {
        "properties": {
          "task": {
            "properties": {
              "inputs": {
                "required": ["design_dirs"],
                "properties": {
                  "design_dirs": {
                    "type": "array",
                    "minItems": 1
                  }
                }
              }
            }
          }
        }
      }
    }
  ],
  "additionalProperties": false
}
